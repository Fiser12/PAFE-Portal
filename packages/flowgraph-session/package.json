{
  "name": "flowgraph-session",
  "version": "0.1.0",
  "description": "Observable single-writer shell for flowgraph-core",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./dist/index.d.mts",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck:prod": "tsc -p tsconfig.json --noEmit",
    "clean": "tsc -b --clean",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts --project session"
  },
  "dependencies": {
    "flowgraph-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsdown": "^0.16.8",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "zod": "4.4.3"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts"
  }
}
