{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PAYLOAD_SECRET",
    "DATABASE_URL",
    "BETTER_AUTH_SECRET",
    "AUTH_SECRET",
    "AUTH_CLIENT_ID",
    "AUTH_CLIENT_SECRET",
    "NEXT_PUBLIC_SERVER_URL",
    "VERCEL_PROJECT_PRODUCTION_URL",
    "SUPER_ADMIN_EMAIL",
    "ENABLED_SUPER_ADMIN",
    "CRON_SECRET",
    "PREVIEW_SECRET",
    "S3_BUCKET",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "AWS_REGION",
    "RESEND_API_KEY",
    "EMAIL_FROM",
    "EMAIL_FROM_NAME",
    "SEED_MOCK_DATA"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT",
        ".env*"
      ],
      "outputs": [
        ".turbo/**",
        ".next/**",
        ".vercel/**",
        "build/**"
      ]
    },
    "lint": {},
    "devcontainer": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": [
        "^build"
      ]
    },
    "storybook": {
      "cache": false,
      "persistent": true,
      "dependsOn": [],
      "outputs": []
    }
  }
}
