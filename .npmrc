auto-install-peers=true
legacy-peer-deps=true
enable-pre-post-scripts=true
# FlatCompat (eslint.config.mjs) resuelve los plugins por nombre desde apps/web:
# hoisting público para que eslint-config-next encuentre sus plugins con pnpm 10
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
