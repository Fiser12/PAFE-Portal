{
  "name": "web",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test:permissions": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/test-permissions.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.832.0",
    "@payloadcms/admin-bar": "3.85.2",
    "@payloadcms/db-postgres": "3.85.2",
    "@payloadcms/email-resend": "3.85.2",
    "@payloadcms/live-preview-react": "3.85.2",
    "@payloadcms/next": "3.85.2",
    "@payloadcms/payload-cloud": "3.85.2",
    "@payloadcms/plugin-form-builder": "3.85.2",
    "@payloadcms/plugin-import-export": "3.85.2",
    "@payloadcms/plugin-search": "3.85.2",
    "@payloadcms/plugin-seo": "3.85.2",
    "@payloadcms/richtext-lexical": "3.85.2",
    "@payloadcms/storage-s3": "3.85.2",
    "@payloadcms/translations": "3.85.2",
    "@payloadcms/ui": "3.85.2",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@zetesis/payload-taxonomies": "^0.2.2",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "geist": "^1.4.2",
    "graphql": "^16.11.0",
    "lucide-react": "^0.378.0",
    "next": "15.3.9",
    "next-sitemap": "^4.2.3",
    "payload": "3.85.2",
    "payload-auth": "^1.8.4",
    "prism-react-renderer": "^2.4.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.45.4",
    "rrule": "^2.8.1",
    "sharp": "^0.33.5",
    "swr": "^2.3.4",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.10",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "22.5.4",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.29.0",
    "eslint-config-next": "15.3.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.10",
    "typescript": "5.7.3"
  },
  "peerDependencies": {
    "@types/json-schema": "^7.0.15"
  },
  "engines": {
    "node": ">=22",
    "pnpm": "^9 || ^10"
  }
}
